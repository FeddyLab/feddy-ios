    "feddy.error.network" : {
      "comment" : "Shown when a request fails because the device cannot reach the API.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Netzwerkfehler. Verbindung prüfen und erneut versuchen." } },
