        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Nous l'enverrons dès que vous serez de nouveau en ligne." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "オンラインに戻ったら送信します。" } }
      }
    },
