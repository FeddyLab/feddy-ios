    "Feddy.identify(…) ran in the host app on launch with the values above. Open dashboard.feddy.app to confirm this user appeared.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Feddy.identify(…) wurde beim Start in der Host-App mit den obigen Werten ausgeführt. Öffnen Sie dashboard.feddy.app, um zu bestätigen, dass dieser Benutzer erschienen ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Feddy.identify(…) ran in the host app on launch with the values above. Open dashboard.feddy.app to confirm this user appeared."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Feddy.identify(…) se ejecutó al iniciar la app host con los valores anteriores. Abre dashboard.feddy.app para confirmar que este usuario apareció."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Feddy.identify(…) s'est exécuté au lancement dans l'application hôte avec les valeurs ci-dessus. Ouvrez dashboard.feddy.app pour confirmer que cet utilisateur est apparu."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Feddy.identify(…) は起動時にホストアプリで上記の値で実行されました。dashboard.feddy.app を開いて、このユーザーが追加されたことを確認してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "宿主 App 在启动时使用上面的值调用了 Feddy.identify(…)。打开 dashboard.feddy.app 即可确认该用户已出现。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "宿主 App 在啟動時使用上面的值呼叫了 Feddy.identify(…)。打開 dashboard.feddy.app 即可確認該使用者已出現。"
          }
        }
      }
    },
