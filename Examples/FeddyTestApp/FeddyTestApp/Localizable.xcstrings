    "Edit DemoConfig.swift or set the FEDDY_API_KEY env var on the Run scheme.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bearbeiten Sie DemoConfig.swift oder setzen Sie die Umgebungsvariable FEDDY_API_KEY im Run-Schema."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Edit DemoConfig.swift or set the FEDDY_API_KEY env var on the Run scheme."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Edita DemoConfig.swift o establece la variable de entorno FEDDY_API_KEY en el esquema de ejecución."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Modifiez DemoConfig.swift ou définissez la variable d'environnement FEDDY_API_KEY dans le schéma d'exécution."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "DemoConfig.swift を編集するか、Run スキームに FEDDY_API_KEY 環境変数を設定してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请编辑 DemoConfig.swift，或在 Run scheme 中设置 FEDDY_API_KEY 环境变量。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請編輯 DemoConfig.swift，或在 Run scheme 中設定 FEDDY_API_KEY 環境變數。"
          }
        }
      }
    },
